# Valeurs par défaut NON sensibles. Ne jamais committer de secret ici.
# Surcharger dans .env.local (gitignoré) pour le local, et via les variables
# d'environnement du serveur en prod.

APP_ENV=dev
APP_SECRET=change_me_in_env_local

###> doctrine/doctrine-bundle ###
# postgresql par défaut. Le mot de passe réel va dans .env.local.
DATABASE_URL="postgresql://palabrae:change_me@127.0.0.1:5432/palabrae?serverVersion=16&charset=utf8"
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=change_me_in_env_local
###< lexik/jwt-authentication-bundle ###

###> nelmio/cors-bundle ###
# Restreindre aux origines réelles du front en prod. Jamais "*" en prod.
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=1878e164b50532e399ed3fd0f37beb56
###< symfony/framework-bundle ###

###> symfony/routing ###
# Configure how to generate URLs in non-HTTP contexts, such as CLI commands.
# See https://symfony.com/doc/current/routing.html#generating-urls-in-commands
DEFAULT_URI=http://localhost
###< symfony/routing ###
